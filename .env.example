# ========================================
# RongRani Frontend Environment Variables
# ========================================
# 
# Development Mode (.env.local):
# Use localhost URLs to work with local backend
# Production Mode (.env.production):
# Use deployed service URLs
#
# ========================================

# API Configuration
# For development: http://localhost:5000
# For production: https://chirkut-ghor.onrender.com
VITE_API_BASE_URL=http://localhost:5000

# Socket.io Configuration (Real-time Updates)
# For development: http://localhost:5000
# For production: https://chirkut-ghor.onrender.com
VITE_SOCKET_URL=http://localhost:5000

# Site URL (Used for SEO and OpenGraph meta tags)
# For development: http://localhost:5173
# For production: https://chirkut-ghor.vercel.app
VITE_SITE_URL=http://localhost:5173
